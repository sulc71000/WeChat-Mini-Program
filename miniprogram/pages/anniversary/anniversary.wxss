/* =====================================================
   anniversary.wxss - 优化版
===================================================== */

/* ===== 页面容器 ===== */
.page-wrap {
  min-height: 100vh;
  background: #FFF5F5;
}

/* ===== 固定导航栏（白色标准样式）===== */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 500;
  background: #FFFFFF;
  padding-top: calc(env(safe-area-inset-top) + 150rpx);
  border-bottom: 1rpx solid #F0F0F0;
}

.nav-bar-inner {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

/* 标题居中 */
.nav-title {
  font-size: 30rpx;
  font-weight: 400;
  color: #333333;
  position: absolute;
  left: 50%;
  transform: translateX(-50%) translateY(-90rpx);
  white-space: nowrap;
}

/* 右侧胶囊按钮 */
.nav-add-btn {
  position: absolute;
  left: 50%;
  top: 10rpx;
  transform: translateX(-50%);
  width: 120rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.35);
}

.nav-add-icon {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: 500;
  line-height: 1;
}

/* ===== 导航栏占位（防止内容被导航栏遮挡）===== */
.nav-placeholder {
  height: calc(88rpx + env(safe-area-inset-top) + 150rpx);
}

/* ===== 滚动区域（上下留白，防遮挡）===== */
.scroll-area {
  height: calc(100vh - 88rpx - env(safe-area-inset-top) - 150rpx - 110rpx - env(safe-area-inset-bottom));
}

/* ===== 英雄卡片 ===== */
.hero-card {
  margin: 24rpx 24rpx 0;
  border-radius: 24rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF4E4E 100%);
  position: relative;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.35);
  min-height: 200rpx;
}

/* 置顶状态：添加金色边框 */
.hero-card.hero-pinned {
  border: 3rpx solid #FFD700;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.35), 0 0 20rpx rgba(255, 215, 0, 0.3);
}

/* 置顶角标 */
.hero-pin-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 32rpx;
  z-index: 2;
  background: rgba(255, 215, 0, 0.9);
  border-radius: 50%;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

.hero-bg-deco {
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 40rpx;
}

.hero-left {
  flex: 1;
}

.hero-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.hero-name {
  font-size: 42rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
  margin-bottom: 16rpx;
}

.hero-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
}

.hero-right {
  display: flex;
  align-items: flex-end;
  flex-shrink: 0;
  margin-left: 24rpx;
}

.hero-num {
  font-size: 110rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

.hero-unit {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 600;
  margin-bottom: 16rpx;
  margin-left: 6rpx;
}

.hero-today {
  flex-shrink: 0;
}

.hero-today-emoji {
  font-size: 80rpx;
  line-height: 1;
}

/* ===== 列表区域 ===== */
.section {
  margin: 24rpx 24rpx 0;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.05);
}

.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F5F0EB;
  transition: background 0.15s;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item:active {
  background: #FFF5F5;
}

.item-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.item-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.dot-future { background: #FF6B6B; }
.dot-today  { background: #FF9900; }
.dot-past   { background: #BBBBBB; }

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.item-date-sub {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-top: 6rpx;
}

.item-right {
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 数字徽章 */
.item-badge {
  display: flex;
  align-items: center;
  border-radius: 12rpx;
  overflow: hidden;
  height: 56rpx;
}

.badge-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFFFF;
  padding: 0 10rpx 0 12rpx;
  height: 100%;
  display: flex;
  align-items: center;
  white-space: nowrap;
}

.badge-num {
  font-size: 30rpx;
  font-weight: 800;
  color: #FFFFFF;
  padding: 0 8rpx 0 2rpx;
  height: 100%;
  display: flex;
  align-items: center;
  font-variant-numeric: tabular-nums;
}

.badge-unit {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  font-weight: 600;
  padding: 0 12rpx 0 0;
  height: 100%;
  display: flex;
  align-items: center;
}

.badge-future {
  background: linear-gradient(90deg, #FF6B6B 0%, #FF8E8E 100%);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.3);
}

.badge-today {
  background: linear-gradient(90deg, #FF9900 0%, #FFB833 100%);
  box-shadow: 0 2rpx 8rpx rgba(255, 153, 0, 0.3);
}

.badge-past {
  background: linear-gradient(90deg, #888888 0%, #AAAAAA 100%);
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 140rpx 60rpx;
}

.empty-icon {
  font-size: 110rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #555555;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #AAAAAA;
  text-align: center;
}

/* ===== 底部安全区（为 TabBar 留白）===== */
.bottom-safe {
  height: calc(110rpx + env(safe-area-inset-bottom) + 20rpx);
}

/* =====================================================
   详情弹层 - 木板风格
===================================================== */
.detail-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 800;
}

.detail-panel {
  position: fixed;
  top: 50%;
  left: 40rpx;
  right: 40rpx;
  transform: translateY(-50%);
  border-radius: 32rpx;
  overflow: hidden;
  z-index: 801;
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.4);
}

/* 木纹背景 */
.wood-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(165deg, #8B5E3C 0%, #A0714F 25%, #7D5235 50%, #9A6845 75%, #8B5E3C 100%);
  overflow: hidden;
}

.wood-grain {
  position: absolute;
  left: 0; right: 0;
  height: 3rpx;
  border-radius: 50%;
  opacity: 0.15;
  background: #5C3D1E;
}

.g1 { top: 18%; transform: rotate(-1deg) scaleX(1.1); }
.g2 { top: 45%; transform: rotate(0.5deg) scaleX(1.05); }
.g3 { top: 72%; transform: rotate(-0.8deg) scaleX(1.08); }

.detail-inner {
  position: relative;
  z-index: 1;
  padding: 40rpx;
}

.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 48rpx;
}

.detail-close {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-close text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.detail-title {
  flex: 1;
  text-align: center;
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.detail-edit-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-edit-icon {
  font-size: 30rpx;
}

/* 大数字区 */
.detail-num-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
  padding: 40rpx 0;
  background: rgba(0, 0, 0, 0.18);
  border-radius: 20rpx;
}

.detail-big-label {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.75);
  font-weight: 500;
  margin-bottom: 12rpx;
}

.detail-big-num-wrap {
  display: flex;
  align-items: flex-end;
}

.detail-big-num {
  font-size: 140rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
  text-shadow: 0 4rpx 16rpx rgba(0,0,0,0.3);
}

.detail-big-unit {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 600;
  margin-bottom: 20rpx;
  margin-left: 8rpx;
}

.detail-big-today {
  font-size: 80rpx;
  letter-spacing: 8rpx;
}

/* 信息行 */
.detail-info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.15);
}

.detail-info-row:last-of-type {
  border-bottom: none;
}

.detail-info-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.65);
}

.detail-info-val {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 操作按钮组 */
.detail-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 40rpx;
  flex-wrap: wrap;
}

.detail-action-btn {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0 8rpx;
}

/* 置顶按钮 */
.detail-pin-action {
  background: rgba(255, 215, 0, 0.85);
  color: #7A4A00;
}

.detail-pin-action:active {
  background: rgba(255, 215, 0, 1);
}

/* 取消置顶按钮 */
.detail-unpin-action {
  background: rgba(255, 255, 255, 0.25);
  color: #FFFFFF;
}

.detail-unpin-action:active {
  background: rgba(255, 255, 255, 0.35);
}

.detail-edit-action {
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
}

.detail-edit-action:active {
  background: rgba(255, 255, 255, 0.3);
}

.detail-delete-action {
  background: rgba(255, 59, 48, 0.75);
  color: #FFFFFF;
}

.detail-delete-action:active {
  background: rgba(255, 59, 48, 0.9);
}

/* =====================================================
   添加/编辑纪念日弹窗（底部滑入）
===================================================== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 900;
}

.modal-box {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 901;
  /* 底部留白给 TabBar（约 110rpx）*/
  padding-bottom: calc(110rpx + env(safe-area-inset-bottom));
  max-height: 88vh;
  display: flex;
  flex-direction: column;
}

.modal-handle {
  width: 80rpx;
  height: 8rpx;
  background: #E0E0E0;
  border-radius: 4rpx;
  margin: 20rpx auto 8rpx;
  flex-shrink: 0;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 40rpx;
  border-bottom: 1rpx solid #F0F0F0;
  flex-shrink: 0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  background: #F5F5F5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999999;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 32rpx 40rpx;
  padding-bottom: 32rpx;
}

.form-group {
  margin-bottom: 36rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #666666;
  display: block;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 96rpx;
  background: #F7F7F7;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 32rpx;
  color: #1A1A1A;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.form-input.input-active {
  border-color: #FF6B6B;
  background: #FFF5F5;
}

.input-placeholder {
  color: #CCCCCC;
}

/* 公历/农历切换 */
.calendar-switch {
  display: flex;
  background: #F7F7F7;
  border-radius: 16rpx;
  padding: 6rpx;
  gap: 6rpx;
}

.switch-btn {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #999999;
  font-weight: 500;
  transition: all 0.2s;
}

.switch-active {
  background: #FFFFFF;
  color: #FF6B6B;
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

/* Picker 选择器 */
.form-picker {
  height: 96rpx;
  background: #F7F7F7;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.form-picker.picker-active {
  border-color: #FF6B6B;
  background: #FFF5F5;
}

.picker-value {
  font-size: 32rpx;
  color: #1A1A1A;
}

.picker-placeholder {
  font-size: 32rpx;
  color: #CCCCCC;
}

.picker-arrow {
  font-size: 40rpx;
  color: #CCCCCC;
  font-weight: 300;
}

/* 底部固定按钮（弹窗内部固定，不随内容滚动） */
.modal-footer {
  flex-shrink: 0;
  display: flex;
  gap: 24rpx;
  padding: 16rpx 40rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  border-top: 1rpx solid #F0F0F0;
}

.footer-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
}

.cancel-btn {
  background: #F5F5F5;
  color: #666666;
}

.confirm-btn {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.4);
}

.confirm-btn:active {
  opacity: 0.88;
}

/* 农历辅助说明文字 */
.lunar-hint {
  font-size: 22rpx;
  color: #AAAAAA;
  margin-top: 12rpx;
  padding-left: 4rpx;
}

/* 公历农历同一行两个 picker */
.date-row {
  display: flex;
  gap: 20rpx;
}

.date-row .form-group-inner {
  flex: 1;
}

.date-row .form-group-inner .form-label {
  margin-bottom: 12rpx;
}

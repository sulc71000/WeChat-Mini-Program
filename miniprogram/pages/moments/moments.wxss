/* moments.wxss - 微信朋友圈风格动态页 */

/* ==================== 页面布局 ==================== */
.container {
  min-height: 100vh;
  background: var(--bg-color);
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.page-content {
  padding: var(--spacing-sm) var(--spacing-md);
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

/* ==================== 动态列表 ==================== */
.moment-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.moment-item {
  padding: var(--spacing-md);
}

/* ==================== 用户信息 ==================== */
.moment-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: var(--spacing-sm);
}

.moment-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-small);
  margin-right: var(--spacing-sm);
  background: var(--primary-pale);
}

.moment-user {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.moment-name {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 500;
}

.moment-time {
  font-size: var(--font-xs);
  color: var(--text-hint);
  margin-top: 4rpx;
}

/* ==================== 内容 ==================== */
.moment-content {
  margin-bottom: var(--spacing-sm);
}

.content-text {
  font-size: var(--font-base);
  color: var(--text-primary);
  line-height: 1.7;
  word-break: break-all;
}

/* ==================== 图片 ==================== */
.moment-images {
  display: grid;
  gap: 8rpx;
  margin-bottom: var(--spacing-sm);
}

.moment-images[grid-cols="1"] {
  grid-template-columns: 1fr;
}

.moment-images[grid-cols="2"] {
  grid-template-columns: repeat(2, 1fr);
}

.moment-images[grid-cols="3"] {
  grid-template-columns: repeat(3, 1fr);
}

.moment-images[grid-cols="4"] {
  grid-template-columns: repeat(4, 1fr);
}

.moment-images[grid-cols="5"],
.moment-images[grid-cols="6"],
.moment-images[grid-cols="7"],
.moment-images[grid-cols="8"],
.moment-images[grid-cols="9"] {
  grid-template-columns: repeat(3, 1fr);
}

.image-item {
  aspect-ratio: 1;
  border-radius: var(--radius-small);
  overflow: hidden;
  background: var(--bg-gray);
}

.image-item.single {
  aspect-ratio: 16/9;
  max-height: 400rpx;
}

.image-img {
  width: 100%;
  height: 100%;
}

/* ==================== 操作栏 ==================== */
.moment-actions {
  display: flex;
  align-items: center;
  gap: var(--spacing-lg);
  padding-top: var(--spacing-sm);
  border-top: 1rpx solid var(--border-color);
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: var(--spacing-xs);
}

.action-icon {
  font-size: 36rpx;
}

.action-count {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

/* ==================== 评论 ==================== */
.moment-comments {
  margin-top: var(--spacing-sm);
  padding: var(--spacing-sm);
  background: var(--bg-gray);
  border-radius: var(--radius-small);
}

.comment-item {
  font-size: var(--font-sm);
  line-height: 1.6;
  color: var(--text-secondary);
}

.comment-item + .comment-item {
  margin-top: 8rpx;
}

.comment-author {
  color: var(--text-primary);
  font-weight: 500;
}

/* ==================== 浮动发布按钮 ==================== */
.fab {
  position: fixed;
  right: var(--spacing-lg);
  bottom: calc(160rpx + env(safe-area-inset-bottom));
  width: 100rpx;
  height: 100rpx;
  background: var(--primary-gradient);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-medium);
  z-index: 100;
  transition: transform 0.2s;
}

.fab:active {
  transform: scale(0.95);
}

.fab-icon {
  font-size: 56rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

/* ==================== 评论输入 ==================== */
.comment-input-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  padding-bottom: calc(var(--spacing-sm) + env(safe-area-inset-bottom));
  background: var(--bg-white);
  border-top: 1rpx solid var(--border-color);
  z-index: 1001;
}

.comment-input {
  flex: 1;
  height: 80rpx;
  background: var(--bg-gray);
  border-radius: var(--radius-round);
  padding: 0 var(--spacing-md);
  font-size: var(--font-base);
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx var(--spacing-lg);
}

.empty-icon {
  font-size: 160rpx;
  opacity: 0.5;
  margin-bottom: var(--spacing-md);
}

.empty-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-xs);
}

.empty-desc {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.6;
}

/* ==================== 加载状态 ==================== */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl);
  gap: 12rpx;
}

.loading-dot {
  width: 12rpx;
  height: 12rpx;
  background: var(--text-hint);
  border-radius: 50%;
  animation: loadingPulse 1.4s infinite ease-in-out both;
}

.loading-dot:nth-child(1) { animation-delay: -0.32s; }
.loading-dot:nth-child(2) { animation-delay: -0.16s; }
.loading-dot:nth-child(3) { animation-delay: 0s; }

@keyframes loadingPulse {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

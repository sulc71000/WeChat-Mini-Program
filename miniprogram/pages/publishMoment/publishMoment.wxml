<view class="container">
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="nav-cancel" bindtap="cancel">取消</view>
    <text class="nav-title">发布动态</text>
    <view class="nav-publish {{content || images.length > 0 ? 'ready' : ''}}" bindtap="publish">
      <text class="publish-text">发布</text>
    </view>
  </view>

  <!-- 内容输入 -->
  <view class="content-section">
    <textarea 
      class="content-input" 
      placeholder="记录今天的美好时刻..." 
      maxlength="500"
      value="{{content}}"
      bindinput="onContentInput"
      placeholder-class="placeholder"
    ></textarea>
    <text class="char-count">{{content.length}}/500</text>
  </view>

  <!-- 图片上传 -->
  <view class="image-section">
    <view class="image-list">
      <view class="image-item" wx:for="{{images}}" wx:key="index">
        <image class="preview-img" src="{{item}}" mode="aspectFill"></image>
        <view class="delete-btn" bindtap="deleteImage" data-index="{{index}}">
          <text class="delete-icon">✕</text>
        </view>
      </view>
      <view class="add-image" wx:if="{{images.length < 9}}" bindtap="chooseImage">
        <text class="add-icon">+</text>
        <text class="add-text">图片</text>
      </view>
    </view>
  </view>

  <!-- 加载提示 -->
  <view class="loading-tip" wx:if="{{loading}}">
    <text>正在发布...</text>
  </view>
</view>

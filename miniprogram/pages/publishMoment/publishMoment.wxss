/* publishMoment.wxss - 简洁精致的发布页面 */

/* ==================== 页面布局 ==================== */
.container {
  min-height: 100vh;
  background: var(--bg-color);
  display: flex;
  flex-direction: column;
}

/* ==================== 导航栏 ==================== */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) var(--spacing-md);
  padding-top: calc(var(--spacing-sm) + env(safe-area-inset-top));
  background: var(--bg-white);
  border-bottom: 1rpx solid var(--border-color);
}

.nav-cancel {
  font-size: var(--font-base);
  color: var(--text-secondary);
  padding: var(--spacing-xs) var(--spacing-sm);
}

.nav-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

.nav-publish {
  padding: var(--spacing-xs) var(--spacing-sm);
}

.nav-publish.ready {
  color: var(--primary);
}

.nav-publish:not(.ready) {
  color: var(--text-hint);
}

.publish-text {
  font-size: var(--font-base);
  font-weight: 500;
}

/* ==================== 内容输入 ==================== */
.content-section {
  flex: 1;
  padding: var(--spacing-md);
  position: relative;
}

.content-input {
  width: 100%;
  min-height: 300rpx;
  background: var(--bg-white);
  border-radius: var(--radius-medium);
  padding: var(--spacing-md);
  font-size: var(--font-base);
  color: var(--text-primary);
  line-height: 1.7;
}

.content-input::placeholder {
  color: var(--text-hint);
}

.char-count {
  position: absolute;
  bottom: var(--spacing-lg);
  right: var(--spacing-lg);
  font-size: var(--font-xs);
  color: var(--text-hint);
}

/* ==================== 图片区域 ==================== */
.image-section {
  padding: var(--spacing-md);
  background: var(--bg-white);
}

.image-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--spacing-xs);
}

.image-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: var(--radius-small);
  overflow: hidden;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 24rpx;
  color: #FFFFFF;
}

.add-image {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--bg-gray);
  border-radius: var(--radius-small);
  border: 2rpx dashed var(--border-color);
}

.add-icon {
  font-size: 48rpx;
  color: var(--text-hint);
  font-weight: 300;
}

.add-text {
  font-size: var(--font-xs);
  color: var(--text-hint);
  margin-top: 4rpx;
}

/* ==================== 加载提示 ==================== */
.loading-tip {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  padding: var(--spacing-md) var(--spacing-lg);
  background: rgba(0, 0, 0, 0.7);
  border-radius: var(--radius-round);
  z-index: 1000;
}

.loading-tip text {
  font-size: var(--font-base);
  color: #FFFFFF;
}
